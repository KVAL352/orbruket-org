---
import BaseLayout from '../layouts/BaseLayout.astro';

const testimonials = [
  {
    quote: 'Som kommunikasjonsansvarlig i Kirkens Bymisjon hadde Kati oversikt over små og store tiltak og aktiviteter, en forståelse for de store linjene og et blikk for enkelthistoriene som beveger. Stor takk for din faglighet og ditt engasjerte blikk.',
    author: 'Arne L. Lynngård',
    role: 'Daglig leder, Kirkens Bymisjon i Bergen',
  },
  {
    quote: 'Kati jobbet som vikar og frilanser i min tid som kommunikasjonssjef i Bob- Bergen og Omegn Boligbyggelag. Hun har en fin penn og et smittende humør, og leverer alltid gode artikler - jeg anbefaler henne varmt som ordbruksmedarbeider.',
    author: 'Ole Irgens',
    role: 'Kommunikasjonssjef, Tryg',
  },
  {
    quote: 'Gjennom ni år i fagtidsskriftet Vestlandsk Landbruk utmerka Kati seg med å skrive eit prikkfritt og levande nynorsk. Kati kan gjøre gull av gråstein. Tallause reportasjar frå vestlandske gardsbruk var prega av hennar faglege innsikt, engasjement og kontaktskapande evner.',
    author: 'Gerd Lithun',
    role: 'Tidligere redaktør, Vestlandsk Landbruk',
  },
  {
    quote: 'Kati lar seg lett engasjere, noe som smitter over i tekstene, og hun har et friskt og levende, men samtidig presist språk. Hennes flerkulturelle kompetanse og bakgrunn innen sosialantropologi gjør at hun skriver særlig godt innenfor mangfoldsfeltet.',
    author: 'Kristine Moskvil Thorsen',
    role: 'Avdelingsleder, Kirkens Bymisjon i Bergen',
  },
];
---

<BaseLayout title="Referanser" description="Hva oppdragsgivere sier om samarbeid med Ordbruket.">
  <div class="page-header">
    <div class="container">
      <h1>Referanser</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="testimonial-grid">
        {testimonials.map((t) => (
          <div class="testimonial">
            <blockquote>&laquo;{t.quote}&raquo;</blockquote>
            <div class="testimonial-author">{t.author}</div>
            <div class="testimonial-role">{t.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
