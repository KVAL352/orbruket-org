---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt" description="La oss jobbe sammen — ta kontakt i dag!">
  <div class="page-header">
    <div class="container">
      <h1>Kontakt</h1>
      <p>La oss jobbe sammen — ta kontakt i dag!</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Ta gjerne kontakt</h3>
          <p>
            Kontakt meg på e-post, mobil eller fyll ut skjemaet under.
          </p>

          <div style="margin-top: 2rem;">
            <div class="contact-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <a href="mailto:kati.indrefjord@gmail.com">kati.indrefjord@gmail.com</a>
            </div>
            <div class="contact-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:+4792452055">924 52 055</a>
            </div>
            <div class="contact-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Bergen, Norge
            </div>
          </div>
        </div>

        <div>
          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />

            <label for="name">Navn</label>
            <input type="text" id="name" name="name" />

            <label for="email">E-post *</label>
            <input type="email" id="email" name="email" required />

            <label for="subject">Emne *</label>
            <input type="text" id="subject" name="subject" required />

            <label for="message">Melding *</label>
            <textarea id="message" name="message" required></textarea>

            <button type="submit" class="btn">Send</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
