---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const portfolioItems = (await getCollection('portfolio')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Portfolio" description="Eit utval av arbeid utført av Ordbruket — artiklar, rapportar og kommunikasjonsoppdrag.">
  <div class="page-header">
    <div class="container">
      <h1>Portfolio</h1>
      <p>Eit utval av arbeid eg har gjort for ulike oppdragsgivarar</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {portfolioItems.length > 0 ? (
        <div class="card-grid">
          {portfolioItems.map((item) => (
            <a href={`/portfolio/${item.id}/`} class="card" style="text-decoration: none; color: inherit;">
              {item.data.image && (
                <img src={item.data.image} alt={item.data.title} class="card-image" />
              )}
              <div class="card-body">
                <div class="card-meta">
                  {item.data.client && <span>{item.data.client}</span>}
                  {item.data.client && ' — '}
                  {new Date(item.data.date).toLocaleDateString('nb-NO', {
                    month: 'long',
                    year: 'numeric',
                  })}
                </div>
                <h3>{item.data.title}</h3>
                <p>{item.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: var(--color-text-light);">
          Portfolioinnhald kjem snart.
        </p>
      )}
    </div>
  </section>
</BaseLayout>
