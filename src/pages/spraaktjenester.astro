---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Språktjenester" description="Ordbruket tilbyr tekstproduksjon, språkvask, oversettelse, innhaldsproduksjon for sosiale medier og transkripsjon.">
  <div class="page-header">
    <div class="container">
      <h1>Språktjenester</h1>
      <p>Profesjonelle tenester tilpassa ditt behov — frå enkeltoppdrag til langsiktig samarbeid</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></div>
          <h3>Tekstproduksjon</h3>
          <p>
            Artiklar, reportasjar, intervju, kronikkar, nyheitssaker og
            featurestoff. Lang erfaring frå journalistikk og
            kommunikasjonsarbeid gir tekstar som treff målgruppa.
          </p>
        </div>

        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h10"/></svg></div>
          <h3>Språkvask og korrektur</h3>
          <p>
            Grundig gjennomgang av tekstar på bokmål og nynorsk.
            Korrekturlesing, språkleg bearbeiding og kvalitetssikring
            av alt frå rapportar til nettsider.
          </p>
        </div>

        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          <h3>Oversettelse</h3>
          <p>
            Profesjonell omsetting frå engelsk til norsk. Tilpassa
            målgruppe og kanal, anten det gjeld fagspråk eller
            meir uformell kommunikasjon.
          </p>
        </div>

        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
          <h3>Sosiale medier</h3>
          <p>
            Innhaldsproduksjon for sosiale medier. Tekst og
            innhaldsstrategi tilpassa ulike plattformer og
            målgrupper.
          </p>
        </div>

        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></div>
          <h3>Transkripsjon</h3>
          <p>
            Nøyaktig transkribering av intervju, møte, konferansar
            og anna lydmateriale. Levering i ønska format.
          </p>
        </div>

        <div class="service-item">
          <div class="service-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="17" r=".5"/></svg></div>
          <h3>Rådgivning</h3>
          <p>
            Kommunikasjonsrådgivning og skrivehjelp. Sparring
            på tekst og strategi for å nå fram med bodskapen din.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="text-align: center; max-width: 600px;">
      <h2>Interessert?</h2>
      <p style="color: var(--color-text-light); margin: 1rem 0 2rem;">
        Ta gjerne kontakt for ein uforpliktande prat om korleis eg kan hjelpe deg.
      </p>
      <a href="/kontakt/" class="btn">Ta kontakt</a>
    </div>
  </section>
</BaseLayout>
