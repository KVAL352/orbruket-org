---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Om Ordbruket" description="Om Kati Foss Indrefjord og Ordbruket — over 30 års erfaring med journalistikk og kommunikasjon.">
  <div class="page-header">
    <div class="container">
      <h1>Om Ordbruket</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="about-content">
        <div>
          <div style="width: 100%; height: 300px; background: var(--color-bg-alt); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--color-secondary);">
            Profilbilde
          </div>
        </div>
        <div class="about-text">
          <h2>Kati Foss Indrefjord</h2>
          <p>
            Eg er journalist og kommunikasjonsrådgivar med over 30 års erfaring.
            Gjennom Ordbruket tilbyr eg profesjonelle språktenester til
            verksemder, organisasjonar og offentlege instansar.
          </p>
          <p>
            Med mastergrad i PR og strategisk kommunikasjon og lang erfaring frå
            ulike redaksjonar og kommunikasjonsavdelingar, leverer eg tekstar som
            treff målgruppa — anten det er på bokmål, nynorsk eller omsett frå
            engelsk.
          </p>

          <div class="cv-section">
            <h3>Språkkompetanse</h3>
            <div class="cv-item">
              <strong>Norsk bokmål og nynorsk</strong>
              <span>Morsmål</span>
            </div>
            <div class="cv-item">
              <strong>Engelsk</strong>
              <span>Flytande</span>
            </div>
            <div class="cv-item">
              <strong>Spansk og tysk</strong>
              <span>Gode kunnskapar</span>
            </div>
          </div>

          <div class="cv-section">
            <h3>Utdanning</h3>
            <div class="cv-item">
              <strong>Master i PR og strategisk kommunikasjon</strong>
            </div>
            <div class="cv-item">
              <strong>Journalistutdanning</strong>
            </div>
          </div>

          <div class="cv-section">
            <h3>Erfaring (utval)</h3>
            <div class="cv-item">
              <strong>Frilansjournalist og kommunikasjonsrådgivar</strong>
              <span>Ordbruket</span>
            </div>
            <div class="cv-item">
              <strong>Kommunikasjonsrådgivar</strong>
              <span>Kirkens Bymisjon Bergen</span>
            </div>
            <div class="cv-item">
              <strong>Journalist</strong>
              <span>Diverse redaksjonar, 30+ år</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
